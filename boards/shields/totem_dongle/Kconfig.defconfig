if SHIELD_TOTEM_DONGLE

config ZMK_KEYBOARD_NAME
    default "Totem"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

# Totem has two halves (left and right)
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# 2 peripherals + 5 BT profiles = 7 total connections
config BT_MAX_CONN
    default 7

config BT_MAX_PAIRED
    default 7

endif
